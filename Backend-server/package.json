{
  "name": "orin-backend-server",
  "version": "1.0.0",
  "description": "Backend-for-Frontend server for Orin - handles background jobs, webhooks, and server-side operations",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
